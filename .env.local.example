# Copy to .env.local and fill in. Never commit .env.local.

# Anthropic (Claude Sonnet 4.5) — optional. When unset the LLM stub in
# lib/anthropic.ts is used (Task 4b deferred per SPEC.md §12).
ANTHROPIC_API_KEY=

# Postgres — Vercel Postgres / Neon. Vercel auto-injects this env var when
# you add the Postgres integration to the project (Storage → Postgres).
# For local dev: copy the connection string from the Vercel Postgres
# dashboard or directly from Neon. Format:
#   postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=

# Google Maps Geocoding + Places Autocomplete — optional. When set, used
# for unit / apartment-level address resolution. When empty we fall back
# to OSM Nominatim (street-level only — no unit data for AU).
# Enable both APIs in your Google Cloud project:
#   - Geocoding API
#   - Places API
# Restrict the key by HTTP referrer (your Vercel domain) or by IP.
GOOGLE_GEOCODING_API_KEY=

# Debug: when true, the ArcGIS helper logs the full query URL.
NEXT_PUBLIC_DEBUG=false
